# Application
APP_NAME=Tawiza
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# API
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Database
# SECURITY: Change default password in production
DATABASE_URL=postgresql+asyncpg://tawiza:CHANGE_ME_IN_PRODUCTION@localhost:5433/tawiza  # Port 5433: docker-compose mappe 5433->5432
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Redis (for caching and message queue)
REDIS_URL=redis://localhost:6380/0  # Port 6380: docker-compose mappe 6380->6379

# MLflow
# IMPORTANT: Port 5001 to avoid conflicts (default 5000 often used)
MLFLOW_TRACKING_URI=http://localhost:5001
MLFLOW_EXPERIMENT_NAME=tawiza-training
MLFLOW_ARTIFACT_LOCATION=s3://mlflow-artifacts

# MinIO (S3-compatible storage)
# IMPORTANT: Port 9002 to avoid conflicts with Portainer (port 9000)
# SECURITY: Change default credentials in production
MINIO_ENDPOINT=localhost:9002
MINIO_ACCESS_KEY=CHANGE_ME_IN_PRODUCTION
MINIO_SECRET_KEY=CHANGE_ME_IN_PRODUCTION_USE_STRONG_PASSWORD
MINIO_BUCKET=tawiza-models
MINIO_SECURE=false

# DVC
DVC_REMOTE=s3://tawiza-data
DVC_REMOTE_ENDPOINT=http://localhost:9002

# Label Studio
# IMPORTANT: Port 8082 (mapped from container port 8080)
# SECURITY: Only allow trusted Label Studio instances (SSRF protection)
LABEL_STUDIO_URL=http://localhost:8082
LABEL_STUDIO_API_KEY=CHANGE_ME_GENERATE_SECURE_API_KEY
LABEL_STUDIO_PROJECT_ID=1
# Comma-separated list of allowed domains for SSRF protection (leave empty for localhost-only in dev)
LABEL_STUDIO_ALLOWED_DOMAINS=
# Allow localhost connections (set to false in production)
LABEL_STUDIO_ALLOW_LOCALHOST=true

# ERPNext
# SECURITY: Use environment-specific credentials
ERPNEXT_URL=https://your-erpnext-instance.com
ERPNEXT_API_KEY=CHANGE_ME_YOUR_API_KEY
ERPNEXT_API_SECRET=CHANGE_ME_YOUR_API_SECRET

# vLLM Serving
VLLM_URL=http://localhost:8002  # Port 8002: evite conflit avec ChromaDB (8001)
VLLM_MODEL_NAME=meta-llama/Llama-2-7b-chat-hf
VLLM_API_KEY=optional_api_key

# Ollama (Local LLM Server)
OLLAMA__BASE_URL=http://localhost:11434
OLLAMA__URL=http://localhost:11434
OLLAMA__TIMEOUT=120
OLLAMA__POOL_CONNECTIONS=20
OLLAMA__POOL_MAXSIZE=40

# =============================================================================
# Data Sources - French Government APIs
# =============================================================================

# INSEE API (statistics, SIRENE enterprise data)
# Register free at: https://api.insee.fr
# Required for: SIRENE enterprise search, regional statistics
INSEE_CLIENT_ID=
INSEE_CLIENT_SECRET=

# France Travail API (job market data)
# Register free at: https://francetravail.io
# Required for: job offers, labor market statistics
FRANCE_TRAVAIL_CLIENT_ID=
FRANCE_TRAVAIL_CLIENT_SECRET=

# Other data sources (BODACC, BOAMP, DVF, BAN) require NO authentication

# =============================================================================
# LLM Cloud Providers (optional, fallback if Ollama unavailable)
# =============================================================================

# Groq (free tier, rate-limited)
# Register at: https://console.groq.com
GROQ_API_KEY=

# OpenRouter (paid, access to Claude, GPT-4, etc.)
# Register at: https://openrouter.ai
OPENROUTER_API_KEY=

# Vector Database (pgvector) - Phase 2
VECTORDB__ENABLED=true
VECTORDB__EMBEDDING_DIM=768
VECTORDB__EMBEDDING_MODEL=nomic-embed-text
VECTORDB__CHUNK_SIZE=512
VECTORDB__CHUNK_OVERLAP=50
VECTORDB__SEARCH_LIMIT_DEFAULT=10
VECTORDB__SEARCH_DISTANCE_THRESHOLD=1.0

# Phase 3: LitServe LLM Optimization (2-5x faster embeddings)
# Set to true to enable LitServe for automatic request batching
VECTORDB__USE_LITSERVE=false
VECTORDB__LITSERVE_URL=http://localhost:8005  # Port 8005: evite conflit avec ChromaDB (8001)

# LLaMA-Factory
LLAMA_FACTORY_MODELS_DIR=/models
LLAMA_FACTORY_DATA_DIR=/data
LLAMA_FACTORY_OUTPUT_DIR=/output

# OpenRLHF
OPENRLHF_NUM_GPUS=1
OPENRLHF_RAY_ADDRESS=auto

# ROCm Configuration
ROCM_PATH=/opt/rocm
HIP_PLATFORM=amd
HSA_OVERRIDE_GFX_VERSION=  # Set to your GPU version if needed (e.g., 10.3.0)

# Training Configuration
TRAINING_BATCH_SIZE=4
TRAINING_GRADIENT_ACCUMULATION_STEPS=4
TRAINING_LEARNING_RATE=2e-5
TRAINING_NUM_EPOCHS=3
TRAINING_MAX_SEQ_LENGTH=2048
TRAINING_LORA_RANK=8
TRAINING_LORA_ALPHA=16

# Retraining Triggers
RETRAINING_SCHEDULE=0 2 * * 0  # Cron: Every Sunday at 2 AM
RETRAINING_MIN_NEW_SAMPLES=100
RETRAINING_ACCURACY_THRESHOLD=0.85

# Monitoring
PROMETHEUS_PORT=9090
GRAFANA_PORT=3003  # Port 3003: evite conflit avec Next.js (3000)
EVIDENTLY_PORT=8080

# Deployment
CANARY_TRAFFIC_PERCENTAGE=10
ROLLBACK_ERROR_THRESHOLD=0.1
DEPLOYMENT_TIMEOUT=600

# Feature Flags
ENABLE_AUTO_ANNOTATION=true
ENABLE_ACTIVE_LEARNING=true
ENABLE_CONTINUOUS_LEARNING=true
ENABLE_CANARY_DEPLOYMENT=true

# Security (CRITICAL - MUST CHANGE IN PRODUCTION)
# Generate a secure SECRET_KEY with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE_ME_IN_PRODUCTION_USE_SECURE_RANDOM_STRING_AT_LEAST_32_CHARS
SECURITY__SECRET_KEY=${SECRET_KEY}
SECURITY__JWT_ALGORITHM=HS256
SECURITY__JWT_EXPIRATION_MINUTES=60
SECURITY__API_KEY_HEADER=X-API-Key

# Rate Limiting (requests per minute)
RATE_LIMIT_PER_IP=100
RATE_LIMIT_BURST=20
RATE_LIMIT_GLOBAL=1000

# Request Validation
MAX_REQUEST_SIZE_MB=10

# Observability
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Anonymous Telemetry (see TELEMETRY.md)
# Set to false to disable all anonymous usage telemetry
TELEMETRY_ENABLED=true
