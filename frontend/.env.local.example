# Tawiza Frontend Configuration
# Copy this file to .env.local and adjust values

# Backend API URL (required)
NEXT_PUBLIC_API_URL=http://localhost:8000

# WebSocket URL (for real-time chat with TAJINE)
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws

# Anonymous telemetry
# Set to false to disable all telemetry
NEXT_PUBLIC_TELEMETRY_ENABLED=true

# Error tracking (optional - Sentry/GlitchTip DSN)
# NEXT_PUBLIC_SENTRY_DSN=

# Authentication bypass (ONLY behind a trusted external auth proxy)
# Mounts a mock admin user and skips the login screen. Value is inlined at BUILD
# time, so changing it requires rebuilding the frontend (not just a restart).
# MUST be paired with the server-side SKIP_AUTH=true (see ../.env.example) —
# setting only one causes a redirect loop / blank dashboard. Keep it unset
# (auth ON) unless an external identity proxy (Cloudflare Access, Authelia, ...)
# sits in front of the app.
# NEXT_PUBLIC_SKIP_AUTH=true
